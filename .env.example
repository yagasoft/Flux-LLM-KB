# Example local configuration. Copy to .env and adjust locally.
# Do not commit .env.

FLUX_KB_DATABASE_URL=postgresql://flux:flux@localhost:5432/flux_llm_kb
FLUX_KB_TEST_DATABASE_URL=postgresql://flux:flux@localhost:5432/flux_llm_kb_test
FLUX_KB_TOKEN_BUDGET=4000
FLUX_KB_CAPTURE_ENABLED=true
FLUX_KB_API_HOST=127.0.0.1
FLUX_KB_API_PORT=8765
FLUX_KB_RABBITMQ_URL=amqp://flux:flux@localhost:5672/flux
FLUX_KB_RABBITMQ_MANAGEMENT_URL=http://127.0.0.1:15672
FLUX_KB_RABBITMQ_USERNAME=flux
FLUX_KB_RABBITMQ_PASSWORD=flux
FLUX_KB_RABBITMQ_PREFETCH=4
FLUX_KB_RABBITMQ_RETRY_DELAY_MS=30000
FLUX_KB_RABBITMQ_DELIVERY_LIMIT=8
FLUX_KB_CONSUMER_CORPUS_CONCURRENCY=4
FLUX_KB_CONSUMER_MAIL_CONCURRENCY=1
FLUX_KB_CONSUMER_AUTOMATION_CONCURRENCY=1
FLUX_KB_CALLBACK_ALLOWLIST=
FLUX_KB_CALLBACK_SIGNING_SECRET=
FLUX_KB_CALLBACK_TIMEOUT_SECONDS=5
FLUX_KB_REDACTIONS_ENABLED=false
FLUX_KB_SEARCH_INDEX_JOB_LIMIT=250
FLUX_KB_SEARCH_INDEX_PAGE_SIZE=100
FLUX_KB_SEARCH_INDEX_EMBEDDING_BATCH_SIZE=16
FLUX_KB_SEARCH_INDEX_TEXT_MAX_CHARS=12000
FLUX_KB_MAIL_IMAP_POLL_INTERVAL_SECONDS=60
FLUX_KB_MAIL_IMAP_USE_IDLE=true
FLUX_KB_MAIL_POST_PROCESS_DEFAULT_POLICY=move_to_processed
# Store real OAuth token references outside this public repo.
# FLUX_KB_MAIL_IMAP_OAUTH_REFRESH_TOKEN=
